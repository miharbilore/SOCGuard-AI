# SOCGuard AI - Environment Configuration Template
# Copy this file to .env.local and fill in your real API keys.
# NEVER commit .env.local to version control.

# Governance
ENABLE_LLM_AGENTS=false
ALLOW_AUTO_APPROVAL=false
ALLOW_PRODUCTION_MUTATION=false
REQUIRE_HUMAN_REVIEW=true
REQUIRE_SANITIZATION=true

# Primary LLM Provider (e.g., GROQ, OPENAI_COMPATIBLE)
LLM_PROVIDER=GROQ
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=<model-name-placeholder>
LLM_API_KEY=<server-side-api-key-placeholder>

# Optional Fallback Provider (Used for reliability, not rate-limit evasion)
FALLBACK_LLM_PROVIDER=OPENAI_COMPATIBLE
FALLBACK_LLM_BASE_URL=<fallback-base-url-placeholder>
FALLBACK_LLM_MODEL=<fallback-model-placeholder>
FALLBACK_LLM_API_KEY=<fallback-server-side-api-key-placeholder>

# Runtime Safety Limits
MAX_CANDIDATES_PER_RUN=3
MAX_CYCLES_PER_RUN=5
MIN_INTERVAL_MS=10000
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
